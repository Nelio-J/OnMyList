{% extends 'base.html.twig' %}

{% block title %}Search Results for "{{ query }}"{% endblock %}

{% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
{% endblock %}

{% block body %}
  <div class="wrapper" data-controller="svg-animation modal">
    {{ include('components/background/_pattern_mataura.html.twig') }}

    <header class="header-content">
      <h1 class="title">Search results for: "{{ query }}"</h1>

      <dialog id="backlogDialog" class="backlog-modal" role="dialog" aria-modal="true" data-modal-target="dialog">
      <form id="backlogForm" method="post" action="{{ path('app_backlog_additem') }}">
        <input type="hidden" name="type" id="modal-type" data-modal-target="type">
        <input type="hidden" name="name" id="modal-name" data-modal-target="name">
        <input type="hidden" name="spotify_id" id="modal-spotify-id" data-modal-target="spotifyId">
        <input type="hidden" name="image" id="modal-image" data-modal-target="image">
        <input type="hidden" name="release_date" id="modal-release-date" data-modal-target="releaseDate">
        <input type="hidden" name="artists" id="modal-artists" data-modal-target="artists">

        <p>
          <label> Choose a backlog:
            <select name="backlog_uuid" id="modal-backlog-select" required>
              {% if backlogs is empty %}
                <option value="" aria-label="No backlogs yet" disabled selected>No backlogs yet</option>
              {% endif %}
              {% for backlog in backlogs %}
                <option value="{{ backlog.uuid }}">{{ backlog.name }}</option>
              {% endfor %}
            </select>
            <a href="{{ path('app_backlog_new') }}">{{ ux_icon('mynaui:plus-solid', {class: 'back-arrow-icon'}, {width: '28px', height: '28px'}) }}</a>
          </label>
        </p>

        <div>
          <button value="cancel" formmethod="dialog" type="button" class="btn modal-button" data-action="click->modal#close">Cancel</button>
          <button id="confirmButton" type="submit" class="btn modal-button">Add</button>
        </div>
      </form>
      </dialog>

    </header>
    
    <div class="search-results">
      {% for item in results %}
        <div class="search-result-item">
        
          {% if item.image %}
            <img src="{{ item.image }}" alt="{{ item.name }}" class="result-image">
          {% else %}
            <img class="result-image placeholder-thumbnail"></img>
          {% endif %}

          <div class="result-content">
            <h3 class="result-title">{{ item.name }}</h3>

            {% if item.type == 'artist' %}
              {# <p class="result-type">Artist</p> #}
            {% elseif item.type == 'album' %}
              {# <p class="result-type">Album</p> #}
              <div class="result-meta">
                <p class="result-artist"><strong>Artist:</strong> {{ item.artist_display }}</p>
                <p class="result-release"><strong>Released:</strong> {{ item.release_date }}</p>
              </div>
            {% endif %}
            
            <button 
              type="button"
              class="btn open-backlog-modal"
              data-action="click->modal#open"
              data-type="{{ item.type }}"
              data-name="{{ item.name }}"
              data-spotify-id="{{ item.spotify_id }}"
              data-image="{{ item.image }}"
              {% if item.type == 'album' %}
                data-release-date="{{ item.release_date }}"
                data-artists="{{ item.artists|json_encode() }}"
              {% endif %}
            >
              Add to Backlog
            </button>
          </div>
        </div>
      {% else %}
        <p>No results found.</p>
        
      {% endfor %}
    </div>
  </div>
  
{% endblock %}
