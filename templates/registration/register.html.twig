{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="wrapper auth-wrapper" data-controller="svg-animation">
        {{ include('components/background/_pattern_stripes.html.twig') }}

        <div class="auth-card">
            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            <header class="header-content">
                <h1 class="title-alt">Make your account</h1>
            </header>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, {'attr': {'class': 'auth-form'}}) }}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.plainPassword, {
                    label: 'Password'
                }) }}
                <div class="terms-row">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms) }}
                </div>

                {{ include('components/_button.html.twig', {'type': 'submit', 'label': 'Register'}) }}
            {{ form_end(registrationForm) }}

            <p class="mt-3">
                Already have an account? <a href="{{ path('app_login') }}">Login</a>
            </p>
        </div>
    </div>
{% endblock %}
